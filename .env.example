EXPO_PUBLIC_THINGSPEAK_BASE_URL=https://api.thingspeak.com
EXPO_PUBLIC_THINGSPEAK_POLL_INTERVAL_MS=15000

# Config channel (geofence settings — separate from GPS data channel)
EXPO_PUBLIC_THINGSPEAK_CONFIG_CHANNEL_ID=your_config_channel_id
EXPO_PUBLIC_THINGSPEAK_CONFIG_READ_API_KEY=your_config_read_api_key
EXPO_PUBLIC_THINGSPEAK_CONFIG_WRITE_API_KEY=your_config_write_api_key

# Backend incident dispatcher
EXPO_PUBLIC_BACKEND_BASE_URL=http://YOUR_SERVER_IP:4000
